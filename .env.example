# 复制为 .env 后填写。除联网 LLM Demo 外，其余示例无需密钥。
OPENAI_API_KEY=

# 2026-07 官方文档推荐从 GPT-5.6 开始；也可以替换成账户可用、支持工具调用的模型。
OPENAI_MODEL=gpt-5.6

# 可选：使用 OpenAI 兼容服务（DeepSeek/Qwen/中转站等）时填写，详见 docs/setup.md。
# OPENAI_BASE_URL=https://api.deepseek.com

# 可选：开启 LangSmith 追踪。
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-agent-tutorial

