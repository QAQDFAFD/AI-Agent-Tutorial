flowchart TD
  IN["用户请求"] --> L1["输入层：认证、大小限制、注入检测"]
  L1 --> L2["上下文层：权限过滤、来源标记"]
  L2 --> L3["模型层：清晰规则、结构化输出、预算"]
  L3 --> L4["工具层：allowlist、schema、授权、审批、timeout"]
  L4 --> L5["状态层：幂等、checkpoint、租户隔离"]
  L5 --> L6["输出层：引用校验、敏感信息脱敏"]
  L6 --> L7["运行层：限流、trace、告警、人工兜底"]
  L7 --> OUT["答复用户"]
  L4 -.->|"高风险写操作"| HITL["人工审批 / kill switch"]
  HITL -.-> L4
