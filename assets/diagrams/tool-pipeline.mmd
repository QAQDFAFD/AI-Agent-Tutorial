flowchart TD
  P["模型提出工具调用"] --> A{"工具在 allowlist 中？"}
  A -->|"否"| R1["拒绝：UNKNOWN_TOOL"]
  A -->|"是"| J{"参数 JSON 可解析？"}
  J -->|"否"| R2["错误 observation：INVALID_JSON"]
  J -->|"是"| S{"Pydantic schema 校验通过？"}
  S -->|"否"| R3["错误 observation：INVALID_ARGUMENTS<br/>模型可追问或纠正"]
  S -->|"是"| AUTH{"当前用户有权限？"}
  AUTH -->|"否"| R4["拒绝并写入审计日志"]
  AUTH -->|"是"| HITL{"写操作需要人工审批？"}
  HITL -->|"是"| WAIT["暂停，等待 approve / reject"]
  WAIT -->|"批准"| IDEM
  WAIT -->|"拒绝"| R5["记录拒绝，不执行"]
  HITL -->|"否"| IDEM{"幂等键已执行过？"}
  IDEM -->|"是"| CACHE["直接返回上次结果"]
  IDEM -->|"否"| EXEC["在 timeout 内执行工具"]
  EXEC --> SAN["输出脱敏与限长"]
  SAN --> OBS["observation 回传模型"]
  CACHE --> OBS
